# ─── Required ───────────────────────────────────────────
LICENSE_KEY=APEX-XXXX-XXXX-XXXX
GROQ_API_KEY=gsk_your_free_groq_key

# Broker: "oanda" (direct API) or "mt" (MetaTrader 5 via ApexBridge EA)
BROKER=oanda

# OANDA (when BROKER=oanda)
OANDA_API_TOKEN=your-oanda-personal-access-token
OANDA_ACCOUNT_ID=101-001-1234567-001
OANDA_ENV=practice

# MetaTrader bridge (when BROKER=mt) — same secret goes in the EA settings
# MT_BRIDGE_SECRET=pick_a_long_random_string

# ─── Telegram (strongly recommended) ────────────────────
TELEGRAM_BOT_TOKEN=123456:ABC-your-botfather-token
TELEGRAM_CHAT_ID=999999999

# ─── Trading (defaults shown) ───────────────────────────
PAPER_TRADING=true
PAPER_BALANCE=1000
TRADE_SYMBOL=EUR_USD
TIMEFRAME=5m
RISK_PER_TRADE=0.02
STOP_LOSS_PIPS=15
TAKE_PROFIT_PIPS=30
LEVERAGE=30
MAX_SPREAD_PIPS=3.0

# ─── Optional ───────────────────────────────────────────
# ANTHROPIC_API_KEY=sk-ant-...
# SCAN_SYMBOLS=EUR_USD,GBP_USD,USD_JPY,AUD_USD,USD_CAD
# MULTI_SYMBOL=true
# DASHBOARD_URL=https://your-app.up.railway.app
